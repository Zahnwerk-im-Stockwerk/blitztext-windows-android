# Vorlage fuer die echte .env (die echte .env wird NICHT eingecheckt).
# Auf dem VPS: cp .env.example .env  und die Werte eintragen.

# Geheimer OpenAI-Schluessel (von platform.openai.com). Nur hier auf dem Server.
# Den GANZEN Wert nach dem = ersetzen. Dein Schluessel beginnt selbst mit sk- ,
# deshalb steht hier bewusst KEIN sk- (sonst doppeltes sk-sk-...).
OPENAI_API_KEY=HIER-DEINEN-OPENAI-SCHLUESSEL-EINFUEGEN

# Gemeinsames App-Passwort, das die App (Android/Windows) mitschickt.
# Frei waehlbar, jederzeit aenderbar: hier neuen Wert eintragen + Container neu starten.
APP_PASSWORT=bitte-aendern

# Optional: andere OpenAI-Modelle.
STT_MODELL=whisper-1
CHAT_MODELL=gpt-4o-mini

# Test ohne echten OpenAI-Call: STUB_MODUS=1 gibt Platzhaltertext zurueck.
# Im echten Betrieb leer lassen oder 0.
STUB_MODUS=

# "1" = jedes Diktat laeuft lokal (kein OpenAI), egal was die App schickt. Fuer ein
# lokales Backend, das nie in die Cloud darf (z.B. Labor-Tablets mit Patientenbezug).
PRIVAT_ERZWINGEN=
