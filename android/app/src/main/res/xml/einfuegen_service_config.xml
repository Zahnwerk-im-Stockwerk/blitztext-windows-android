<?xml version="1.0" encoding="utf-8"?>
<!-- Bedienungshilfe-Konfiguration: nur das Noetigste, um Text ins fokussierte Feld zu setzen.
     Keine Event-Mitschnitte (typeWindowStateChanged ist das Minimum, wir reagieren nicht darauf). -->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagDefault"
    android:canRetrieveWindowContent="true"
    android:description="@string/einfuegen_service_beschreibung"
    android:notificationTimeout="100" />
