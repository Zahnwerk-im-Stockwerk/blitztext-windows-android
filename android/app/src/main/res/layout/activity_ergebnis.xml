<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Kopfzeile: Logo + Titel + Zeit, rechts das Privat-Badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <ImageView
            android:id="@+id/bild_logo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/logo_zahnwerk"
            android:contentDescription="@string/app_name" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ergebnis_titel"
                android:textColor="@color/text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_zeit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gold"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/badge_privat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ergebnis_privat_badge"
            android:textColor="@color/gruen"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Der erkannte Text, nachbesserbar -->
    <EditText
        android:id="@+id/feld_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="top"
        android:inputType="textMultiLine|textCapSentences"
        android:background="@drawable/karte_hintergrund"
        android:padding="14dp"
        android:textColor="@color/text"
        android:textSize="16sp" />

    <!-- Aktionen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/knopf_kopieren"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/ergebnis_kopieren"
            android:backgroundTint="@color/karte"
            android:textColor="@color/gold" />

        <Button
            android:id="@+id/knopf_teilen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ergebnis_teilen"
            android:backgroundTint="@color/karte"
            android:textColor="@color/gold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/knopf_datei"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/ergebnis_speichern"
            android:backgroundTint="@color/gold"
            android:textColor="@color/nachtblau" />

        <Button
            android:id="@+id/knopf_drucken"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ergebnis_drucken"
            android:backgroundTint="@color/gold"
            android:textColor="@color/nachtblau" />
    </LinearLayout>

</LinearLayout>
